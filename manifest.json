{
  "manifest_version": 3,
  "name": "JIRA Bulk Ticket Creator",
  "version": "1.0.0",
  "description": "Create and upload multiple JIRA tickets at once — each with a title, description, and image.",
  "action": {
    "default_title": "Open JIRA Bulk Creator",
    "default_icon": {
      "16":  "icons/icon.png",
      "48":  "icons/icon.png",
      "128": "icons/icon.png"
    }
  },
  "icons": {
    "16":  "icons/icon.png",
    "48":  "icons/icon.png",
    "128": "icons/icon.png"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage", "sidePanel"],
  "host_permissions": ["<all_urls>"]
}
